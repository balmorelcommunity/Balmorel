*PB Climate Change
QPBSCORE_CO2_G(IY411,G)..
SUM((IA), 
			SUM((IS3,T), IHOURSINST(IS3,T)*IHOURFRAC *(IM_CO2_prod_elec(IY411,G) * 1000 * (VGE_T(IY411,IA,G,IS3,T) 
			+ VHYDROGEN_GH2_T(IY411,IA,G,IS3,T) + VGBIOMETH_T(IY411,IA,G,IS3,T) + VGBIOGASMETHANATION_T(IY411,IA,G,IS3,T) + VGBIOGASUPGRADING_T(IY411,IA,G,IS3,T)) 
			+ IM_CO2_prod_heat(IY411,G) * 1000 * VGH_T(IY411,IA,G,IS3,T))))
+ 
SUM((IA),
((VGKNACCUMNET(IY411,IA,G) *1000) * 1000) * IM_CO2_constr(IY411,G)/GDATA(G,'GDLIFETIME'))
=e=IS_CO2_G(IY411,G);

QPBSCORE_CO2(IY411)..
IS_CO2(IY411) =e=SUM(G, IS_CO2_G(IY411,G))
;

QPBSCORE_CO2_X(IY411)..
IS_CO2_X(IY411) =e=SUM((IRE,IRI), VXKNACCUMNET(IY411,IRE,IRI)*1000/50*PB_LCA_DATA_X(IRE,IRI,IY411,'LCA_CO2_constr'))
;

QPBSCORE_CO2_X_H2(IY411)..
IS_CO2_X_H2(IY411) =e=SUM((IRE,IRI), VXKNACCUMNET(IY411,IRE,IRI)*1000/50*PB_LCA_DATA_X_H2(IRE,IRI,IY411,'LCA_CO2_constr'))
;

QPBLIM_CO2(IY411)..
(IS_CO2(IY411)+IS_CO2_X(IY411)+IS_CO2_X_H2(IY411))/PB_THRESHOLDS_DATA(IY411,'SOS_CO2_sector')=L=TL_CO2(IY411);

QPBSCORE_CO2_F(Y,FFF)..
IS_CO2_F(Y,FFF) =e=SUM((G)$(IGF(G,FFF)), IS_CO2_G(Y,G));


