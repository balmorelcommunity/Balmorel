*PB Climate Change
QPBSCORE_CO2_G(Y,G)..
SUM((IA), 
			SUM((IS3,T), IHOURSINST(IS3,T)*IHOURFRAC *(IM_CO2_prod_elec(Y,G) * 1000 * (VGE_T(Y,IA,G,IS3,T))) 
			
$ifi %HYDROGEN%==yes  + (IM_CO2_prod_elec(Y,G) * 1000 * (VHYDROGEN_GH2_T(Y,IA,G,IS3,T) + VGBIOMETH_T(Y,IA,G,IS3,T) + VGBIOGASMETHANATION_T(Y,IA,G,IS3,T) + VGBIOGASUPGRADING_T(Y,IA,G,IS3,T))) 
			
			+ IM_CO2_prod_heat(Y,G) * 1000 * VGH_T(Y,IA,G,IS3,T)))
+ 
SUM((IA),
((VGKNACCUMNET(Y,IA,G) *1000) * 1000) * IM_CO2_constr(Y,G)/GDATA(G,'GDLIFETIME'))
=e=IS_CO2_G(Y,G);

QPBSCORE_CO2(Y)..
IS_CO2(Y) =e=SUM(G, IS_CO2_G(Y,G))
;

*PB_LCA_DATA_X & PB_LCA_DATA_X_H2 now has year
QPBSCORE_CO2_X(Y)..
IS_CO2_X(Y) =e=SUM((IRE,IRI), VXKNACCUMNET(Y,IRE,IRI)*1000/50*PB_LCA_DATA_X(IRE,IRI,Y,'LCA_CO2_constr')) 
;

QPBSCORE_CO2_X_H2(Y)..
IS_CO2_X_H2(Y) =e=SUM((IRE,IRI), VXKNACCUMNET(Y,IRE,IRI)*1000/50*PB_LCA_DATA_X_H2(IRE,IRI,Y,'LCA_CO2_constr'))
;

QPBLIM_CO2_TL_NO(Y)..
(IS_CO2(Y)+IS_CO2_X(Y)+IS_CO2_X_H2(Y))/PB_THRESHOLDS_DATA(Y,'SOS_CO2_sector') =L= 1;

QPBLIM_CO2_TL(Y)..
(IS_CO2(Y)+IS_CO2_X(Y)+IS_CO2_X_H2(Y))/PB_THRESHOLDS_DATA(Y,'SOS_CO2_sector') =E= TL_CO2(Y);


QPBSCORE_CO2_F(Y,FFF)..
IS_CO2_F(Y,FFF) =e=SUM((G)$(IGF(G,FFF)), IS_CO2_G(Y,G));


